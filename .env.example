PORT=8080

# Database
DATABASE_PORT=5432
DATABASE_USER=expense_user
DATABASE_PASSWORD=expense_pass
DATABASE_NAME=expense_db
DATABASE_HOST=localhost
DATABASE_SYNCHRONIZE=false

# JWT
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# CORS
CORS_ORIGINS=http://localhost:4200,http://localhost:3000

# Environment (development | production | test)
NODE_ENV=development

# S3 — File storage (uses LocalStack in development, AWS in production)
S3_BUCKET=expense-receipts
S3_REGION=us-east-1
S3_ENDPOINT=http://localhost:4566
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# Internal API — Key for internal service-to-service authentication (required in production, min 16 chars)
INTERNAL_API_KEY=

# AI — API key for AI features (optional, used for receipt processing)
AI_API_KEY=
CONFIDENCE_THRESHOLD=0.7